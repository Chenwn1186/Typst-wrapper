{
  "name": "typst-code-wrapper",
  "displayName": "Typst Code Wrapper",
  "description": "Wrap selected Typst code with common functions and user-defined functions via right-click menu",
  "version": "1.1.1",
  "icon": "icon.png",
  "publisher": "ChanWN8264",
  "repository": "https://github.com/Chenwn1186/Typst-wrapper",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typst"
  ],
  "main": "./extension.js",
  "contributes": {
    "submenus": [
      {
        "id": "typst-wrapper.submenu",
        "label": "Typst Code Wrapper"
      }
    ],
    "commands": [
      { "command": "typst-wrapper.strong",         "title": "#strong (Bold)" },
      { "command": "typst-wrapper.emph",           "title": "#emph (Italic)" },
      { "command": "typst-wrapper.lower",          "title": "#lower (Lowercase)" },
      { "command": "typst-wrapper.upper",          "title": "#upper (Uppercase)" },
      { "command": "typst-wrapper.raw",            "title": "#raw (Code)" },
      { "command": "typst-wrapper.highlight",      "title": "#highlight" },
      { "command": "typst-wrapper.underline",      "title": "#underline" },
      { "command": "typst-wrapper.strike",         "title": "#strike" },
      { "command": "typst-wrapper.overline",       "title": "#overline" },
      { "command": "typst-wrapper.sub",            "title": "#sub (Subscript)" },
      { "command": "typst-wrapper.super",          "title": "#super (Superscript)" },
      { "command": "typst-wrapper.smallcaps",      "title": "#smallcaps" },
      { "command": "typst-wrapper.textRed",        "title": "#text(fill: red)" },
      { "command": "typst-wrapper.textBlue",       "title": "#text(fill: blue)" },
      { "command": "typst-wrapper.alignCenter",    "title": "#align(center)" },
      { "command": "typst-wrapper.alignLeft",      "title": "#align(left)" },
      { "command": "typst-wrapper.alignRight",     "title": "#align(right)" },
      { "command": "typst-wrapper.box",            "title": "#box" },
      { "command": "typst-wrapper.block",          "title": "#block" },
      { "command": "typst-wrapper.rect",           "title": "#rect" },
      { "command": "typst-wrapper.rectDashed",     "title": "#rect (dashed)" },
      { "command": "typst-wrapper.pad",            "title": "#pad" },
      { "command": "typst-wrapper.columns",        "title": "#columns(2)" },
      { "command": "typst-wrapper.link",           "title": "#link" },
      { "command": "typst-wrapper.footnote",       "title": "#footnote" },
      { "command": "typst-wrapper.quote",          "title": "#quote" },
      { "command": "typst-wrapper.userFunctions",  "title": "User Functions" }
    ],
    "menus": {
      "typst-wrapper.submenu": [
        { "command": "typst-wrapper.strong",         "group": "1_text@1" },
        { "command": "typst-wrapper.emph",           "group": "1_text@2" },
        { "command": "typst-wrapper.lower",          "group": "1_text@3" },
        { "command": "typst-wrapper.upper",          "group": "1_text@4" },
        { "command": "typst-wrapper.raw",            "group": "1_text@5" },
        { "command": "typst-wrapper.highlight",      "group": "2_decor@1" },
        { "command": "typst-wrapper.underline",      "group": "2_decor@2" },
        { "command": "typst-wrapper.strike",         "group": "2_decor@3" },
        { "command": "typst-wrapper.overline",       "group": "2_decor@4" },
        { "command": "typst-wrapper.sub",            "group": "3_script@1" },
        { "command": "typst-wrapper.super",          "group": "3_script@2" },
        { "command": "typst-wrapper.smallcaps",      "group": "3_script@3" },
        { "command": "typst-wrapper.textRed",        "group": "4_color@1" },
        { "command": "typst-wrapper.textBlue",       "group": "4_color@2" },
        { "command": "typst-wrapper.alignCenter",    "group": "5_align@1" },
        { "command": "typst-wrapper.alignLeft",      "group": "5_align@2" },
        { "command": "typst-wrapper.alignRight",     "group": "5_align@3" },
        { "command": "typst-wrapper.box",            "group": "6_layout@1" },
        { "command": "typst-wrapper.block",          "group": "6_layout@2" },
        { "command": "typst-wrapper.rect",           "group": "6_layout@3" },
        { "command": "typst-wrapper.rectDashed",     "group": "6_layout@4" },
        { "command": "typst-wrapper.pad",            "group": "6_layout@5" },
        { "command": "typst-wrapper.columns",        "group": "6_layout@6" },
        { "command": "typst-wrapper.link",           "group": "7_doc@1" },
        { "command": "typst-wrapper.footnote",       "group": "7_doc@2" },
        { "command": "typst-wrapper.quote",          "group": "7_doc@3" },
        { "command": "typst-wrapper.userFunctions",  "group": "zz_funcs" }
      ],
      "editor/context": [
        {
          "submenu": "typst-wrapper.submenu",
          "when": "editorHasSelection && editorLangId == typst",
          "group": "1_typst"
        }
      ]
    }
  }
}
